<tr><td>open</td><td>https://prep.ryder.com/en-us<datalist><option>https://www.ryder.com/used-trucks/inventory</option><option>https://www.ryder.com/en-us</option><option>https://prep.ryder.com/en-us</option></datalist></td><td></td></tr>
<tr><td>click</td><td>css=#navigation-primary-uvs<datalist><option>xpath=//a[@id='navigation-primary-uvs']/div</option><option>xpath=//*/text()[normalize-space(.)='Buy Used Trucks']/parent::*</option><option>xpath=//li[4]/a/div</option><option>css=#navigation-primary-uvs > div</option><option>link=All Ryder</option><option>css=#navigation-primary-allryder</option><option>css=#navigation-primary-uvs</option></datalist></td><td></td></tr>
<tr><td>click</td><td>css=#navigation-secondary-uvs-featured-buy-trucks<datalist><option>xpath=//a[@id='navigation-secondary-uvs-featured-buy-trucks']/span/span</option><option>xpath=(.//*[normalize-space(text()) and normalize-space(.)='Back to main menu'])[16]/following::span[2]</option><option>xpath=(.//*[normalize-space(text()) and normalize-space(.)='Back to main menu'])[17]/preceding::span[1]</option><option>xpath=//*/text()[normalize-space(.)='Buy Trucks']/parent::*</option><option>xpath=//div[7]/div/div/div[3]/div[2]/a/span/span</option><option>navigation-secondary-allryder-featured-contact-info</option><option>css=#navigation-secondary-allryder-featured-contact-info</option><option>css=#navigation-secondary-uvs-featured-buy-trucks</option></datalist></td><td></td></tr>
<tr><td>runScript</td><td>return (document.querySelector('.results-per-page-container span.body--sm')?.innerText.trim().startsWith("Select") ? 12 : parseInt(document.querySelector('.results-per-page-container span.body--sm').innerText.match(/\d+/)[0], 10))<datalist><option>parseInt(document.querySelector('.results-per-page-container .body--sm')             .innerText.match(/\d+/)[0], 10);</option><option>return parseInt(document.querySelector('.results-per-page-container .body--sm')             .innerText.match(/\d+/)[0], 10);</option><option>var span = document.querySelector('.results-per-page-container .body--sm'); var text = span ? span.innerText.trim() : ""; text === "Select" ? 12 : parseInt(text.match(/\d+/)[0], 10);</option><option>var span = document.querySelector('.results-per-page-container .body--sm'); var text = span ? span.innerText.trim() : ""; text === "Select:" ? 12 : parseInt(text.match(/\d+/)[0], 10);</option><option>return (document.querySelector('.results-per-page-container span.body--sm')?.innerText.trim().startsWith("Select") ? 12 : parseInt(document.querySelector('.results-per-page-container span.body--sm').innerText.match(/\d+/)[0], 10))</option></datalist></td><td>perPage</td></tr>
<tr><td>runScript</td><td>var container = document.querySelector('.filter-pills'); if (!container) return [];  return Array.from(container.querySelectorAll('button'))     .map(function(btn) {         return btn.innerText.trim();     });<datalist><option>var container = document.querySelector('.filter-pills'); if (!container) return [];  return Array.from(container.querySelectorAll('button'))     .map(function(btn) {         return btn.innerText.trim();     });</option><option>var container = document.querySelector('.filter-pills');  if (!container) {     storedVars['savedUVSInventoryFilterPills'] = JSON.stringify([]); } else {     var buttons = Array.from(container.querySelectorAll('button'))         .map(function(btn) {             return btn.innerText.trim();         });      storedVars['savedUVSInventoryFilterPills'] = JSON.stringify(buttons); }</option><option>return document.querySelector('.filter-pills');  if (!container) {     storedVars['savedUVSInventoryFilterPills'] = JSON.stringify([]); } else {     var buttons = Array.from(container.querySelectorAll('button'))         .map(function(btn) {             return btn.innerText.trim();         });      storedVars['savedUVSInventoryFilterPills'] = JSON.stringify(buttons); }</option><option>var container = document.querySelector('.filter-pills');  if (!container) {     storedVars['savedUVSInventoryFilterPills'] = JSON.stringify([]); } else {     var buttons = Array.from(container.querySelectorAll('button'))         .map(function(btn) {             return btn.innerText.trim();         });      storedVars['savedUVSInventoryFilterPills'] = JSON.stringify(buttons); }var container = document.querySelector('.filter-pills'); if (!container) return [];  return Array.from(container.querySelectorAll('button'))     .map(function(btn) {         return btn.innerText.trim();     });</option><option>var callback = arguments[arguments.length - 1];  var container = document.querySelector('.filter-pills');  if (!container) {     callback([]);     return; }  var buttons = Array.from(container.querySelectorAll('button'))     .map(function(btn) {         return btn.innerText.trim();     });  callback(buttons);</option><option>var container = document.querySelector('.filter-pills'); if (!container) return [];  return Array.from(container.querySelectorAll('button'))     .map(function(btn) {         return btn.innerText.trim();     });</option></datalist></td><td>savedUVSInventoryFilterPills</td></tr>
<tr><td>runScript</td><td>return Array.from(document.querySelectorAll('div.vehicle-card-container div.vehicle-id'))      .map(div => div.innerText.trim());<datalist><option>vehicle-card-container</option><option>Array.from(document.querySelectorAll('div.vehicle-card-container div.vehicle-id'))      .map(div => div.innerText.trim());</option><option>return Array.from(document.querySelectorAll('div.vehicle-card-container div.vehicle-id'))      .map(div => div.innerText.trim());</option></datalist></td><td>inventoryVehicleIDs</td></tr>
<tr><td>runScript</td><td>return Array.from(document.querySelectorAll('a'))      .map(a => a.id || null);<datalist><option>// Get all <a> elements and return their ids Array.from(document.querySelectorAll('a'))      .map(a => a.id || null);</option><option>Array.from(document.querySelectorAll('a'))      .map(a => a.id || null);</option><option>return Array.from(document.querySelectorAll('a'))      .map(a => a.id || null);</option></datalist></td><td>allLinkIds</td></tr>
