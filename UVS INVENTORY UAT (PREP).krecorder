<tr><td>runScript</td><td>var expectedButtons = ["All", "Available", "Sold", "Reserved"]; var actualButtons = storedVars['savedUVSInventoryFilterPills'] || [];  // Check if all expected buttons are present var missing = expectedButtons.filter(function(btn) {     return actualButtons.indexOf(btn) === -1; });  if (missing.length > 0) {     throw new Error("Missing buttons: " + missing.join(", ")); }  return true;<datalist><option>var expectedButtons = ["All", "Available", "Sold", "Reserved"]; var actualButtons = storedVars['savedUVSInventoryFilterPills'] || [];  // Check if all expected buttons are present var missing = expectedButtons.filter(function(btn) {     return actualButtons.indexOf(btn) === -1; });  if (missing.length > 0) {     throw new Error("Missing buttons: " + missing.join(", ")); }  return true;</option></datalist></td><td></td></tr>
